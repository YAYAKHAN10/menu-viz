# Base URL for 3D assets (GLB/USDZ). Leave unset to serve from local `public/`.
# Set to the R2 public dev URL (or a CDN custom domain) to serve from R2.
# NEXT_PUBLIC_* is inlined at build time, so it must be present for
# `build` / `build:worker` (locally via .env.local, in CI via repo/Cloudflare vars).
NEXT_PUBLIC_CDN_BASE=https://pub-89bf546384844ba7a583b22230631686.r2.dev

# --- asset upload script (scripts/assets.ts) only; not used by the app ---
# Defaults shown; override if needed. The API token is read from .cf-token
# (gitignored) when CLOUDFLARE_API_TOKEN is not set in the environment.
# CLOUDFLARE_ACCOUNT_ID=09abb782bf38f116f993da799ee6e023
# R2_BUCKET=menuviz-assets
